# Database Connection (Direct Connection URI)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Auth Secrets (Min 32 Characters)
JWT_SECRET=your_jwt_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars_here

# Groq AI Keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# Server Port and URL
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Market Simulation
SIMULATION_CRON="0 */6 * * *"
SIMULATION_TRIGGER_AI=true

# Frontend Public API URL
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
