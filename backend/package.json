{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express API server for Klypup Dynamic Pricing Intelligence Dashboard",
  "main": "dist/index.js",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
